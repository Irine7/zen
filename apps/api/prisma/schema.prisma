// prisma/schema.prisma

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

model User {
  id         String   @id @default(uuid())
  email      String   @unique
  name       String?
  password   String   @default("123456")
  zenPoints  Int      @default(0)
	emailVerified Boolean @default(false)
  
	// Связь One-to-One:
	emailVerificationToken EmailVerificationToken?

  // Связи
  bonsais    Bonsai[]
  habits     Habit[]
  refreshTokens RefreshToken[]
	passwordResetTokens PasswordResetToken[]
	inventory  Inventory[]

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Habit {
  id          String   @id @default(uuid())
  title       String
  description String?
  
  // Связь с пользователем
  userId      String
  user        User     @relation(fields: [userId], references: [id])

  // Связь One-to-One с Bonsai (отношение определяется в модели Bonsai)
  bonsai      Bonsai?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Bonsai {
  id             String   @id @default(uuid())
  type           String
  level          Int      @default(1)
  
  // Связь с пользователем
  userId         String
  user           User     @relation(fields: [userId], references: [id])

  // Связь One-to-One с Habit
  // @unique гарантирует, что к одной привычке нельзя привязать два дерева
  habitId        String   @unique
  habit          Habit    @relation(fields: [habitId], references: [id])

  lastWateredAt  DateTime @default(now())
  createdAt      DateTime @default(now())
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model EmailVerificationToken {
  id        String   @id @default(uuid())
  token     String   @unique
  expiresAt DateTime
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Seed {
  id          String   @id @default(uuid())
  type        String   @unique // Например: 'PINE', 'MAPLE', 'SAKURA', 'BAMBOO'
  name        String
  price       Int      @default(0)
  description String?
  
  // Обратная связь: где это семечко находится в инвентарях пользователей
  inventory   Inventory[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Inventory {
  id        String   @id @default(uuid())
  
  // Связь с пользователем
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Связь с семечком
  seedId    String
  seed      Seed     @relation(fields: [seedId], references: [id], onDelete: Cascade)
  
  // Количество купленных семян этого типа у пользователя
  quantity  Int      @default(1)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Уникальный составной индекс: один пользователь может иметь только 
  // одну запись инвентаря для конкретного типа семечка
  @@unique([userId, seedId])
}
